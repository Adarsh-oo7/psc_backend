# Django configuration
DEBUG=True
SECRET_KEY=django-insecure-some-development-key-change-in-production
ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.2,192.168.1.5

# Database configuration
# Set DATABASE_URL to use PostgreSQL: postgresql://user:password@localhost:5432/dbname
# SQLite fallback is used if DATABASE_URL is not provided or empty.
DATABASE_URL=sqlite:///db.sqlite3

# Razorpay Configuration (optional for local dev if not testing payments)
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# AI / LLM Configuration
GEMINI_API_KEY=your_gemini_api_key

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
